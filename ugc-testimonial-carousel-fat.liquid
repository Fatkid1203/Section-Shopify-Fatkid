{%- comment -%}
  Section: UGC Testimonial Carousel - FAt
  File: sections/ugc-testimonial-carousel-fat.liquid
  Online Store 2.0 custom section. Self-contained CSS + minimal JS, scoped via section.id.
{%- endcomment -%}

{%- liquid
  assign sec_id = section.id
  assign s = section.settings

  assign show_rating_row = s.show_rating_row
  assign show_arrows = s.show_arrows
  assign show_badges = s.show_badges
  assign show_card_stars = s.show_card_stars
  assign autoplay_enabled = s.enable_autoplay
  assign autoplay_speed = s.autoplay_speed | default: 5

  assign rating_stars = s.rating_star_count | default: 5
  assign blocks_count = section.blocks.size
-%}

<style>
  #shopify-section-{{ sec_id }} .ugcfat-root,
  #shopify-section-{{ sec_id }} .ugcfat-root * {
    box-sizing: border-box;
  }

  #shopify-section-{{ sec_id }} .ugcfat-root {
    --ugcfat-bg: {{ s.bg_color | default: '#ffffff' }};
    --ugcfat-text: {{ s.text_color | default: '#1a1a1a' }};
    --ugcfat-heading: {{ s.heading_color | default: '#111111' }};
    --ugcfat-muted: {{ s.muted_text_color | default: '#6b6b6b' }};
    --ugcfat-star: {{ s.star_color | default: '#FFC400' }};
    --ugcfat-badge-bg: {{ s.badge_bg_color | default: '#ffffff' }};
    --ugcfat-badge-text: {{ s.badge_text_color | default: '#111111' }};
    --ugcfat-arrow-bg: {{ s.arrow_bg_color | default: '#1c5dff' }};
    --ugcfat-arrow-icon: {{ s.arrow_icon_color | default: '#ffffff' }};
    --ugcfat-overlay-opacity: {{ s.card_overlay_opacity | default: 65 | divided_by: 100.0 }};
    --ugcfat-max-width: {{ s.max_width | default: 1280 }}px;
    --ugcfat-pad-top: {{ s.padding_top | default: 64 }}px;
    --ugcfat-pad-bottom: {{ s.padding_bottom | default: 64 }}px;
    --ugcfat-heading-size-desktop: {{ s.heading_size_desktop | default: 44 }}px;
    --ugcfat-heading-size-mobile: {{ s.heading_size_mobile | default: 28 }}px;
    --ugcfat-card-width-desktop: {{ s.card_width_desktop | default: 280 }}px;
    --ugcfat-card-width-mobile: {{ s.card_width_mobile | default: 240 }}px;
    --ugcfat-card-radius: {{ s.card_border_radius | default: 18 }}px;
    --ugcfat-card-gap: {{ s.card_gap | default: 20 }}px;
    --ugcfat-aspect-w: 1696;
    --ugcfat-aspect-h: 2528;

    background-color: var(--ugcfat-bg);
    color: var(--ugcfat-text);
    padding-top: var(--ugcfat-pad-top);
    padding-bottom: var(--ugcfat-pad-bottom);
    overflow: hidden;
    position: relative;
  }

  #shopify-section-{{ sec_id }} .ugcfat-inner {
    max-width: var(--ugcfat-max-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Rating row */
  #shopify-section-{{ sec_id }} .ugcfat-rating-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    text-align: center;
    margin-bottom: 16px;
  }

  #shopify-section-{{ sec_id }} .ugcfat-stars {
    display: inline-flex;
    gap: 2px;
    line-height: 1;
  }

  #shopify-section-{{ sec_id }} .ugcfat-stars svg {
    width: 18px;
    height: 18px;
    fill: var(--ugcfat-star);
    flex-shrink: 0;
  }

  #shopify-section-{{ sec_id }} .ugcfat-rating-text {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ugcfat-muted);
  }

  /* Heading */
  #shopify-section-{{ sec_id }} .ugcfat-heading {
    text-align: center;
    color: var(--ugcfat-heading);
    font-size: var(--ugcfat-heading-size-mobile);
    line-height: 1.15;
    font-weight: 800;
    margin: 0 auto 36px;
    max-width: 880px;
    letter-spacing: -0.01em;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ sec_id }} .ugcfat-heading {
      font-size: var(--ugcfat-heading-size-desktop);
    }
  }

  /* Carousel wrapper / arrows */
  #shopify-section-{{ sec_id }} .ugcfat-carousel-wrap {
    position: relative;
  }

  #shopify-section-{{ sec_id }} .ugcfat-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 60px;
    z-index: 2;
    pointer-events: none;
  }

  #shopify-section-{{ sec_id }} .ugcfat-fade-left {
    left: 0;
    background: linear-gradient(to right, var(--ugcfat-bg), rgba(0,0,0,0));
  }

  #shopify-section-{{ sec_id }} .ugcfat-fade-right {
    right: 0;
    background: linear-gradient(to left, var(--ugcfat-bg), rgba(0,0,0,0));
  }

  #shopify-section-{{ sec_id }} .ugcfat-track {
    display: flex;
    gap: var(--ugcfat-card-gap);
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 6px 10px 18px;
    scrollbar-width: none;
    -ms-overflow-style: none;
    /* Cho phép ảnh đầu/cuối snap vào giữa trên mobile */
    scroll-padding-inline: calc((100% - var(--ugcfat-card-width-mobile)) / 2);
  }

  @media (min-width: 768px) {
    #shopify-section-{{ sec_id }} .ugcfat-track {
      scroll-padding-inline: 10px;
    }
  }

  #shopify-section-{{ sec_id }} .ugcfat-track::-webkit-scrollbar {
    display: none;
    height: 0;
  }

  #shopify-section-{{ sec_id }} .ugcfat-track:focus-visible {
    outline: 2px solid var(--ugcfat-arrow-bg);
    outline-offset: 4px;
  }

  /* Card */
  #shopify-section-{{ sec_id }} .ugcfat-card {
    position: relative;
    flex: 0 0 auto;
    width: var(--ugcfat-card-width-mobile);
    aspect-ratio: var(--ugcfat-aspect-w) / var(--ugcfat-aspect-h);
    border-radius: var(--ugcfat-card-radius);
    overflow: hidden;
    scroll-snap-align: center;
    background-color: #e9e9e9;
    isolation: isolate;
    display: block;
    color: inherit;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ sec_id }} .ugcfat-card {
      width: var(--ugcfat-card-width-desktop);
      scroll-snap-align: start;
    }
  }

  #shopify-section-{{ sec_id }} .ugcfat-card:focus-visible {
    outline: 3px solid var(--ugcfat-arrow-bg);
    outline-offset: 3px;
  }

  @media (hover: hover) {
    #shopify-section-{{ sec_id }} a.ugcfat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 14px 30px rgba(0,0,0,0.18);
    }
    #shopify-section-{{ sec_id }} a.ugcfat-card:hover .ugcfat-card-img {
      transform: scale(1.04);
    }
  }

  #shopify-section-{{ sec_id }} .ugcfat-card-img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  #shopify-section-{{ sec_id }} .ugcfat-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.35s ease;
  }

  #shopify-section-{{ sec_id }} .ugcfat-card-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #ececec, #dcdcdc);
    color: #9a9a9a;
  }

  #shopify-section-{{ sec_id }} .ugcfat-card-placeholder svg {
    width: 40%;
    height: 40%;
    opacity: 0.6;
  }

  #shopify-section-{{ sec_id }} .ugcfat-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 35%, rgba(0,0,0, var(--ugcfat-overlay-opacity)) 100%);
    pointer-events: none;
  }

  #shopify-section-{{ sec_id }} .ugcfat-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    max-width: calc(100% - 24px);
    background-color: var(--ugcfat-badge-bg);
    color: var(--ugcfat-badge-text);
    font-size: 12px;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 999px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    z-index: 1;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }

  #shopify-section-{{ sec_id }} .ugcfat-card-content {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 14px;
    z-index: 1;
    color: #ffffff;
  }

  #shopify-section-{{ sec_id }} .ugcfat-quote {
    font-weight: 700;
    font-size: 14px;
    line-height: 1.35;
    margin: 0 0 8px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-shadow: 0 1px 4px rgba(0,0,0,0.35);
  }

  #shopify-section-{{ sec_id }} .ugcfat-card-stars {
    display: inline-flex;
    gap: 2px;
  }

  #shopify-section-{{ sec_id }} .ugcfat-card-stars svg {
    width: 14px;
    height: 14px;
    fill: var(--ugcfat-star);
  }

  /* Arrow buttons */
  #shopify-section-{{ sec_id }} .ugcfat-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 44px;
    height: 44px;
    min-width: 44px;
    min-height: 44px;
    border-radius: 10px;
    border: none;
    background-color: var(--ugcfat-arrow-bg);
    color: var(--ugcfat-arrow-icon);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 6px 16px rgba(0,0,0,0.18);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  #shopify-section-{{ sec_id }} .ugcfat-arrow:hover {
    transform: translateY(-50%) scale(1.05);
  }

  #shopify-section-{{ sec_id }} .ugcfat-arrow:focus-visible {
    outline: 3px solid var(--ugcfat-arrow-bg);
    outline-offset: 3px;
  }

  #shopify-section-{{ sec_id }} .ugcfat-arrow svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: var(--ugcfat-arrow-icon);
    stroke-width: 2.4;
  }

  #shopify-section-{{ sec_id }} .ugcfat-arrow-prev {
    left: 4px;
  }

  #shopify-section-{{ sec_id }} .ugcfat-arrow-next {
    right: 4px;
  }

  /* Infinite loop enabled — arrows never disabled */

  @media (min-width: 1000px) {
    #shopify-section-{{ sec_id }} .ugcfat-arrow-prev {
      left: -8px;
    }
    #shopify-section-{{ sec_id }} .ugcfat-arrow-next {
      right: -8px;
    }
  }

  /* Placeholder (editor only, no blocks) */
  #shopify-section-{{ sec_id }} .ugcfat-empty-state {
    text-align: center;
    padding: 40px 20px;
    border: 1px dashed #cfcfcf;
    border-radius: 12px;
    color: var(--ugcfat-muted);
    font-size: 14px;
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ sec_id }} .ugcfat-track {
      scroll-behavior: auto;
    }
    #shopify-section-{{ sec_id }} .ugcfat-card,
    #shopify-section-{{ sec_id }} .ugcfat-card-img,
    #shopify-section-{{ sec_id }} .ugcfat-arrow {
      transition: none !important;
    }
  }
</style>

<div class="ugcfat-root" id="ugcfat-{{ sec_id }}">
  <div class="ugcfat-inner">

    {%- if show_rating_row -%}
      <div class="ugcfat-rating-row">
        <span class="ugcfat-stars" aria-hidden="true">
          {%- for i in (1..5) -%}
            {%- if i <= rating_stars -%}
              <svg viewBox="0 0 24 24"><path d="M12 2l2.9 6.6 7.1.6-5.4 4.7 1.7 7-6.3-3.9-6.3 3.9 1.7-7L2 9.2l7.1-.6L12 2z"/></svg>
            {%- else -%}
              <svg viewBox="0 0 24 24" style="opacity:0.3;"><path d="M12 2l2.9 6.6 7.1.6-5.4 4.7 1.7 7-6.3-3.9-6.3 3.9 1.7-7L2 9.2l7.1-.6L12 2z"/></svg>
            {%- endif -%}
          {%- endfor -%}
        </span>
        {%- if s.rating_text != blank -%}
          <span class="ugcfat-rating-text">{{ s.rating_text | escape }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if s.heading != blank -%}
      <h2 class="ugcfat-heading">{{ s.heading | escape }}</h2>
    {%- endif -%}
  </div>

  {%- if blocks_count == 0 -%}
    <div class="ugcfat-inner">
      <div class="ugcfat-empty-state">
        {{ 'Add testimonial card blocks in the section editor to display customer stories here.' }}
      </div>
    </div>
  {%- else -%}
      <div class="ugcfat-carousel-wrap">
        <div class="ugcfat-fade ugcfat-fade-left" aria-hidden="true"></div>
        <div class="ugcfat-fade ugcfat-fade-right" aria-hidden="true"></div>

        {%- if show_arrows -%}
          <button type="button" class="ugcfat-arrow ugcfat-arrow-prev" aria-label="Previous testimonials" data-ugcfat-prev>
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button type="button" class="ugcfat-arrow ugcfat-arrow-next" aria-label="Next testimonials" data-ugcfat-next>
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        {%- endif -%}

        <div
          class="ugcfat-track"
          role="region"
          aria-label="{{ s.heading | default: 'Customer testimonials' | escape }} carousel"
          tabindex="0"
          data-ugcfat-track
          data-autoplay="{{ autoplay_enabled }}"
          data-autoplay-speed="{{ autoplay_speed }}"
        >
          {%- for block in section.blocks -%}
            {%- if block.type == 'testimonial_card' -%}
              {%- liquid
                assign bs = block.settings
                assign has_link = false
                if bs.link_url != blank
                  assign has_link = true
                endif
                assign star_count = bs.star_rating | default: 0
              -%}

              {%- capture card_inner -%}
                <div class="ugcfat-card-img-wrap">
                  {%- if bs.customer_image != blank -%}
                    {{
                      bs.customer_image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        class: 'ugcfat-card-img',
                        alt: bs.image_alt | default: bs.username | default: 'Customer testimonial',
                        sizes: '(min-width: 1000px) 320px, (min-width: 768px) 280px, 240px',
                        widths: '240,320,400,480,640,800,1000,1200'
                    }}
                  {%- else -%}
                    <div class="ugcfat-card-placeholder">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                        <circle cx="8.5" cy="8.5" r="1.5"></circle>
                        <path d="M21 15l-5-5L5 21"></path>
                      </svg>
                    </div>
                  {%- endif -%}
                  <div class="ugcfat-card-overlay" aria-hidden="true"></div>
                </div>

                {%- if show_badges and bs.username != blank -%}
                  <span class="ugcfat-badge">{{ bs.username | escape }}</span>
                {%- endif -%}

                <div class="ugcfat-card-content">
                  {%- if bs.quote != blank -%}
                    <p class="ugcfat-quote">{{ bs.quote | escape }}</p>
                  {%- endif -%}

                  {%- if show_card_stars and star_count > 0 -%}
                    <span class="ugcfat-card-stars" aria-label="Rated {{ star_count }} out of 5 stars">
                      {%- for i in (1..5) -%}
                        {%- if i <= star_count -%}
                          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.9 6.6 7.1.6-5.4 4.7 1.7 7-6.3-3.9-6.3 3.9 1.7-7L2 9.2l7.1-.6L12 2z"/></svg>
                        {%- else -%}
                          <svg viewBox="0 0 24 24" aria-hidden="true" style="opacity:0.35;"><path d="M12 2l2.9 6.6 7.1.6-5.4 4.7 1.7 7-6.3-3.9-6.3 3.9 1.7-7L2 9.2l7.1-.6L12 2z"/></svg>
                        {%- endif -%}
                      {%- endfor -%}
                    </span>
                  {%- endif -%}
                </div>
              {%- endcapture -%}

              {%- if has_link -%}
                <a
                  href="{{ bs.link_url }}"
                  {% if bs.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
                  class="ugcfat-card"
                  {{ block.shopify_attributes }}
                >
                  {{ card_inner }}
                </a>
              {%- else -%}
                <div class="ugcfat-card" {{ block.shopify_attributes }}>
                  {{ card_inner }}
                </div>
              {%- endif -%}

            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
</div>

<script>
  (function () {
    var root = document.getElementById('ugcfat-{{ sec_id }}');
    if (!root) return;

    var track = root.querySelector('[data-ugcfat-track]');
    if (!track) return;

    var prevBtn = root.querySelector('[data-ugcfat-prev]');
    var nextBtn = root.querySelector('[data-ugcfat-next]');
    var autoplay = track.getAttribute('data-autoplay') === 'true';
    var autoplaySpeed = parseFloat(track.getAttribute('data-autoplay-speed')) || 5;
    var prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var autoplayTimer = null;

    /* ── Infinite-loop clone setup ─────────────────────────────────── */
    var CLONE_COUNT = 10; // số card nhân bản mỗi phía
    var realCards = Array.prototype.slice.call(track.querySelectorAll('.ugcfat-card'));
    var totalReal = realCards.length;
    var cloneOffset = 0; // scrollLeft tương ứng với card thật đầu tiên

    function buildClones() {
      if (totalReal === 0) return;
      var n = CLONE_COUNT;

      // Thêm clone của n card CUỐI vào TRƯỚC đầu track
      for (var i = 0; i < n; i++) {
        var idx = (totalReal - 1 - (i % totalReal)) % totalReal;
        if (idx < 0) idx += totalReal;
        var cl = realCards[idx].cloneNode(true);
        cl.setAttribute('aria-hidden', 'true');
        cl.classList.add('ugcfat-clone');
        track.insertBefore(cl, track.firstChild);
      }

      // Thêm clone của n card ĐẦU vào SAU cuối track
      for (var j = 0; j < n; j++) {
        var cl2 = realCards[j % totalReal].cloneNode(true);
        cl2.setAttribute('aria-hidden', 'true');
        cl2.classList.add('ugcfat-clone');
        track.appendChild(cl2);
      }
    }

    function initScrollPosition() {
      // Tính cloneOffset = tổng chiều rộng của n card clone đầu + gap
      var clones = track.querySelectorAll('.ugcfat-clone');
      var headClones = [];
      for (var i = 0; i < clones.length; i++) {
        if (track.children[i] === clones[i]) headClones.push(clones[i]);
        else break;
      }
      var n = CLONE_COUNT;
      var style = window.getComputedStyle(track);
      var gap = parseFloat(style.columnGap || style.gap) || 0;
      var offset = 0;
      var allChildren = track.children;
      for (var k = 0; k < n; k++) {
        offset += allChildren[k].getBoundingClientRect().width + gap;
      }
      cloneOffset = offset;
      track.scrollLeft = cloneOffset;
    }

    buildClones();

    // Chạy sau khi layout xong
    requestAnimationFrame(function () {
      requestAnimationFrame(initScrollPosition);
    });

    /* ── Helpers ───────────────────────────────────────────────────── */
    function getCardWidth() {
      var card = track.querySelector('.ugcfat-card');
      if (!card) return track.clientWidth;
      var style = window.getComputedStyle(track);
      var gap = parseFloat(style.columnGap || style.gap) || 0;
      return card.getBoundingClientRect().width + gap;
    }

    function updateArrowState() {
      if (prevBtn) prevBtn.disabled = false;
      if (nextBtn) nextBtn.disabled = false;
    }

    /* ── Infinite scroll: silent teleport khi vào vùng clone ─────── */
    var isTeleporting = false;

    function checkInfiniteLoop() {
      if (isTeleporting || totalReal === 0) return;
      var cardW = getCardWidth();
      var realWidth = totalReal * cardW;
      var maxReal = cloneOffset + realWidth;

      if (track.scrollLeft <= cloneOffset - cardW * 0.5) {
        // Đang trong vùng clone trước → teleport về cuối phần thật
        isTeleporting = true;
        track.style.scrollBehavior = 'auto';
        track.style.scrollSnapType = 'none'; // Tắt snap để không bị khựng
        track.scrollLeft = track.scrollLeft + realWidth;
        void track.offsetHeight; // Force reflow
        track.style.scrollBehavior = '';
        track.style.scrollSnapType = '';
        isTeleporting = false;
      } else if (track.scrollLeft >= maxReal - cardW * 0.5) {
        // Đang trong vùng clone sau → teleport về đầu phần thật
        isTeleporting = true;
        track.style.scrollBehavior = 'auto';
        track.style.scrollSnapType = 'none';
        track.scrollLeft = track.scrollLeft - realWidth;
        void track.offsetHeight; // Force reflow
        track.style.scrollBehavior = '';
        track.style.scrollSnapType = '';
        isTeleporting = false;
      }
    }

    /* ── scrollByCards với infinite loop liền mạch ─────────────────── */
    function scrollByCards(direction) {
      var amount = getCardWidth();
      track.scrollBy({ left: direction * amount, behavior: prefersReducedMotion ? 'auto' : 'smooth' });
    }

    /* ── Autoplay ──────────────────────────────────────────────────── */
    function stopAutoplay() {
      if (autoplayTimer) {
        clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    }

    function startAutoplay() {
      if (!autoplay || prefersReducedMotion) return;
      stopAutoplay();
      autoplayTimer = setInterval(function () {
        scrollByCards(1);
      }, autoplaySpeed * 1000);
    }

    /* ── Event listeners ───────────────────────────────────────────── */
    if (prevBtn) {
      prevBtn.addEventListener('click', function () { scrollByCards(-1); });
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', function () { scrollByCards(1); });
    }

    track.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowRight') { e.preventDefault(); scrollByCards(1); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); scrollByCards(-1); }
    });

    var scrollTimeout;
    track.addEventListener('scroll', function () {
      // Dùng debounce để chỉ nhảy (teleport) sau khi thao tác scroll hoàn toàn dừng lại,
      // tránh cắt ngang quá trình smooth-scroll / snap của trình duyệt gây khựng.
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(function () {
        checkInfiniteLoop();
      }, 50);
      
      window.requestAnimationFrame(updateArrowState);
    }, { passive: true });

    ['mouseenter', 'focusin', 'touchstart', 'pointerdown'].forEach(function (evt) {
      track.addEventListener(evt, stopAutoplay, { passive: true });
    });
    track.addEventListener('mouseleave', startAutoplay, { passive: true });

    /* ── Drag-to-scroll (mouse) ─────────────────────────────────────── */
    var isDown = false;
    var startX = 0;
    var startScroll = 0;
    var dragged = false;

    track.addEventListener('pointerdown', function (e) {
      if (e.pointerType === 'touch') return;
      isDown = true;
      dragged = false;
      startX = e.clientX;
      startScroll = track.scrollLeft;
      track.setPointerCapture && track.setPointerCapture(e.pointerId);
    });

    track.addEventListener('pointermove', function (e) {
      if (!isDown) return;
      var dx = e.clientX - startX;
      if (Math.abs(dx) > 4) dragged = true;
      track.scrollLeft = startScroll - dx;
    });

    function endDrag() { isDown = false; }
    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointercancel', endDrag);
    track.addEventListener('pointerleave', endDrag);

    track.addEventListener('click', function (e) {
      if (dragged) {
        e.preventDefault();
        e.stopPropagation();
        dragged = false;
      }
    }, true);

    /* ── Init ──────────────────────────────────────────────────────── */
    updateArrowState();
    startAutoplay();

    /* ── Shopify editor ────────────────────────────────────────────── */
    if (window.Shopify && Shopify.designMode) {
      document.addEventListener('shopify:section:load', function (evt) {
        if (evt.target && evt.target.contains(root)) {
          stopAutoplay();
          startAutoplay();
        }
      });
      document.addEventListener('shopify:section:unload', function (evt) {
        if (evt.target && evt.target.contains(root)) {
          stopAutoplay();
        }
      });
      document.addEventListener('shopify:section:select', stopAutoplay);
      document.addEventListener('shopify:block:select', function (evt) {
        var blockEl = evt.target;
        if (blockEl && track.contains(blockEl)) {
          stopAutoplay();
          var rect = blockEl.getBoundingClientRect();
          var trackRect = track.getBoundingClientRect();
          var offset = rect.left - trackRect.left + track.scrollLeft - 20;
          track.scrollTo({ left: offset, behavior: 'smooth' });
        }
      });
    }
  })();
</script>

